# ── VIT-AI Service Environment Variables ──────────────────────────────────────
# Copy to .env and fill in ALL values before starting.
# Variables marked Required cause startup failure if unset.

# Runtime
APP_VERSION=0.1.0
PORT=8000
LOG_LEVEL=INFO

# Model storage (container path — matches COPY models /app/models in Dockerfile)
MODEL_DIR=/app/models

# ── vit-storage integration ────────────────────────────────────────────────────
# Required — URL of the deployed vit-storage service.
VIT_STORAGE_URL=

# ── Internal service authentication ───────────────────────────────────────────
# Required — shared API key for inter-service calls. Generate with: openssl rand -hex 32
VIT_AI_API_KEY=

# ── VIT Chain oracle (Chain ID 7764) ──────────────────────────────────────────
# Required — signing private key of the oracle account.
ORACLE_PRIVATE_KEY=
# Required — deployed address of the UniversalOracle contract on VIT Chain.
UNIVERSAL_ORACLE_ADDRESS=
